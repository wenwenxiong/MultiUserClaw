{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "outDir": "bridge/dist",
    "rootDir": ".",
    "tsBuildInfoFile": "bridge/dist/.tsbuildinfo"
  },
  "include": ["bridge/**/*.ts", "src/**/*.ts", "extensions/**/*.ts"],
  "exclude": ["node_modules", "dist", "bridge/dist", "**/*.test.ts"]
}
